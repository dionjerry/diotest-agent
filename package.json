{
  "name": "diotest-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-platform.mjs",
    "build": "node scripts/build-extension.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:web:open": "node scripts/dev-web.mjs --open",
    "clean:web": "node scripts/clean-web.mjs",
    "build:web": "npm run build --workspace=@diotest/web",
    "typecheck:web": "npm run typecheck --workspace=@diotest/web",
    "dev:api": "npm run dev --workspace=@diotest/api",
    "dev:platform": "node scripts/dev-platform.mjs",
    "build:api": "npm run build --workspace=@diotest/api",
    "typecheck:api": "npm run typecheck --workspace=@diotest/api",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "js-beautify": "^1.15.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.322",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.0.0",
    "prisma": "^6.5.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
